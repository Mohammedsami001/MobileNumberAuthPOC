# ─── App ───────────────────────────────────────────────────────────────────────
# Set to "production" in live environments to suppress _devOtp in API responses
NODE_ENV=development
PORT=3000

# ─── MSG91 Credentials ─────────────────────────────────────────────────────────
# Sign up at https://msg91.com and get your API key from Settings > API Keys
MSG91_API_KEY=your_msg91_api_key_here

# Your DLT-registered Sender ID (6-char, e.g. MYAPPS)
MSG91_SENDER_ID=MYAPPS

# MSG91 OTP Template ID (create an OTP template in MSG91 dashboard → SMS → Templates)
# Template format: "Your OTP for login is ##OTP##. Valid for 5 minutes. -MYAPPS"
MSG91_TEMPLATE_ID=your_template_id_here

# WhatsApp Template Namespace (from Meta Business Manager via MSG91)
# MSG91 WhatsApp number — provided after WhatsApp BSP onboarding
MSG91_WHATSAPP_NUMBER=91XXXXXXXXXX

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Redis Cloud free tier: rediss://:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/otp_auth
# MongoDB Atlas free tier: mongodb+srv://user:pass@cluster.mongodb.net/otp_auth
MONGODB_URI=mongodb://localhost:27017/otp_auth

# ─── OTP Config ────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300       # 5 minutes
OTP_MAX_ATTEMPTS=3           # Block after 3 wrong attempts
OTP_RESEND_COOLDOWN=60       # Seconds before resend is allowed
OTP_LENGTH=6
